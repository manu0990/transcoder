{
  "name": "transcoder",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "postinstall": "npx prisma generate",
    "db:gen": "prisma generate",
